# Lyra OS — Snapper config for the root subvolume (§4)
# Paired with snap-pac (pre/post snapshot around every pacman/Pamac transaction)
# and grub-btrfs (boot menu entries to roll back without a terminal).
SUBVOLUME="/"
FSTYPE="btrfs"
QGROUP=""
SPACE_LIMIT="0.5"
FREE_LIMIT="0.2"

ALLOW_USERS=""
ALLOW_GROUPS="wheel"
SYNC_ACL="yes"

BACKGROUND_COMPARISON="yes"

# Timeline: keep a light rolling history. snap-pac handles the important
# "before this update" snapshots; the timeline is a secondary safety net.
TIMELINE_CREATE="yes"
TIMELINE_CLEANUP="yes"
TIMELINE_MIN_AGE="1800"
TIMELINE_LIMIT_HOURLY="5"
TIMELINE_LIMIT_DAILY="7"
TIMELINE_LIMIT_WEEKLY="2"
TIMELINE_LIMIT_MONTHLY="2"
TIMELINE_LIMIT_YEARLY="0"

# Number cleanup for the pacman pre/post pairs created by snap-pac.
NUMBER_CLEANUP="yes"
NUMBER_MIN_AGE="1800"
NUMBER_LIMIT="20"
NUMBER_LIMIT_IMPORTANT="10"

EMPTY_PRE_POST_CLEANUP="yes"
EMPTY_PRE_POST_MIN_AGE="1800"
