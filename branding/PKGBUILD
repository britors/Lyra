# Maintainer: W3TI <rodrigo@w3ti.com.br>
# Lyra OS branding metapackage: wallpapers, Plymouth, SDDM theme, Plasma defaults.
# Built locally by aur/build-aur.sh. Assets are produced by the generate-*.sh
# scripts (run them before building, or let build.sh do it — see §10/§12).
pkgname=lyra-branding
pkgver=1.0.0
pkgrel=1
pkgdesc="Lyra OS visual identity — wallpapers, Plymouth, SDDM theme, Plasma defaults"
arch=('any')
url="https://w3ti.com.br/lyra"
license=('GPL3')
depends=('plymouth' 'sddm')
install="lyra-branding.install"
# This package overlays files generated into the branding/ tree; build from here.
options=('!strip')

package() {
    local b="${startdir}"

    # --- Wallpapers (KDE layout) ---
    if [[ -d "${b}/wallpapers/generated/usr/share/wallpapers" ]]; then
        install -d "${pkgdir}/usr/share/wallpapers"
        cp -a "${b}/wallpapers/generated/usr/share/wallpapers/." \
              "${pkgdir}/usr/share/wallpapers/"
    fi

    # --- Plymouth theme ---
    install -Dm644 "${b}/plymouth/lyra.plymouth" \
        "${pkgdir}/usr/share/plymouth/themes/lyra/lyra.plymouth"
    install -Dm644 "${b}/plymouth/lyra.script" \
        "${pkgdir}/usr/share/plymouth/themes/lyra/lyra.script"
    install -Dm644 "${b}/assets/logo.png" \
        "${pkgdir}/usr/share/plymouth/themes/lyra/logo.png"

    # --- SDDM theme ---
    install -d "${pkgdir}/usr/share/sddm/themes/lyra"
    install -m644 "${b}/sddm/metadata.desktop" "${b}/sddm/theme.conf" \
        "${b}/sddm/Main.qml" "${pkgdir}/usr/share/sddm/themes/lyra/"
    install -m644 "${b}/assets/background.png" \
        "${pkgdir}/usr/share/sddm/themes/lyra/background.png"

    # --- Boot menu background (GRUB/syslinux) ---
    install -Dm644 "${b}/assets/lyra-boot-bg.png" \
        "${pkgdir}/usr/share/lyra/lyra-boot-bg.png"

    # --- Branded os-release logo target ---
    install -Dm644 "${b}/assets/logo.png" \
        "${pkgdir}/usr/share/pixmaps/lyra.png"
}
