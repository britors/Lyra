# Lyra OS — curated AUR packages (§5/§9).
# Format: <pkgname> <aur-git-url> [local-dep ...]
#   - Built in a clean chroot with makechrootpkg, in the order listed.
#   - local-dep columns name packages built EARLIER in this list that must be
#     installed into the chroot (via makechrootpkg -I) before this one builds
#     (i.e. the AUR-internal dependency chain). Official-repo deps are resolved
#     automatically inside the chroot.
# Curated by the maintainer — NOT "whatever is on the AUR".

# Installer (§11). Calamares was DROPPED from the official Arch repos and is now
# AUR-only — so it must be built here. All its deps are official (no AUR chain).
calamares            https://aur.archlinux.org/calamares.git

# Graphical package store (§5). pamac-aur depends on libpamac-aur (also AUR).
libpamac-aur         https://aur.archlinux.org/libpamac-aur.git
pamac-aur            https://aur.archlinux.org/pamac-aur.git                libpamac-aur

# NVIDIA legacy driver for Maxwell/Pascal/Volta GPUs (§6). DKMS because linux-zen.
nvidia-580xx-utils       https://aur.archlinux.org/nvidia-580xx-utils.git
nvidia-580xx-dkms        https://aur.archlinux.org/nvidia-580xx-dkms.git        nvidia-580xx-utils
lib32-nvidia-580xx-utils https://aur.archlinux.org/lib32-nvidia-580xx-utils.git nvidia-580xx-utils

# W3TI applications (§9)
prosa                https://aur.archlinux.org/prosa.git
fina                 https://aur.archlinux.org/fina.git
# calco              <pending AUR publication — §9/§13>
# pulso              <pending AUR publication — §9/§13>
yay
